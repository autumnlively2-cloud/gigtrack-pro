# ── Server ──────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Auth ─────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ── Stripe ───────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Stripe Price IDs — create these in your Stripe dashboard
# Products > Add product > Add price (recurring)
STRIPE_PRICE_PRO=price_YOUR_PRO_PRICE_ID
STRIPE_PRICE_BUSINESS=price_YOUR_BUSINESS_PRICE_ID

# App URL (used for Stripe redirect and OAuth callbacks)
APP_URL=http://localhost:3001

# ── Uber OAuth ───────────────────────────────────
# Register at: https://developer.uber.com/docs/drivers/guides/authentication
UBER_CLIENT_ID=your_uber_client_id
UBER_CLIENT_SECRET=your_uber_client_secret

# ── Lyft OAuth ───────────────────────────────────
# Register at: https://www.lyft.com/developers
LYFT_CLIENT_ID=your_lyft_client_id
LYFT_CLIENT_SECRET=your_lyft_client_secret
