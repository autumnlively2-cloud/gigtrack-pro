# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Local development: install PostgreSQL and create a database, then set the URL below
# Render: this is set automatically from the linked database
DATABASE_URL=postgresql://localhost:5432/gigtrack

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave blank for localhost only)
# Example: https://gigtrack.onrender.com,https://www.gigtrackpro.com
ALLOWED_ORIGINS=

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string

# ─── App URL (used for OAuth callbacks) ───────────────────────────────────────
APP_URL=http://localhost:3001

# ─── Stripe (https://dashboard.stripe.com/test/apikeys) ──────────────────────
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
STRIPE_PRICE_PRO=price_YOUR_PRO_PRICE_ID
STRIPE_PRICE_BUSINESS=price_YOUR_BUSINESS_PRICE_ID

# ─── Uber OAuth (https://developer.uber.com) ──────────────────────────────────
UBER_CLIENT_ID=your_uber_client_id
UBER_CLIENT_SECRET=your_uber_client_secret

# ─── Lyft OAuth (https://developer.lyft.com) ──────────────────────────────────
LYFT_CLIENT_ID=your_lyft_client_id
LYFT_CLIENT_SECRET=your_lyft_client_secret
